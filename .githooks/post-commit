#!/bin/bash

LOG_FILE="docs/log/index.md"
DATE=$(date +"%Y-%m-%d")

echo "🔍 检查更新日志..."

# 获取最近1条提交（只获取最新的）
COMMIT=$(git log --format="- %s" -1)

echo "📋 当前提交: $COMMIT"

# 检查这条提交是否已存在于日志中
if grep -q "$COMMIT" "$LOG_FILE"; then
    echo "⚠️ 该提交已记录，跳过"
    exit 0
fi

# 检查今天是否已存在记录
if grep -q "## $DATE" "$LOG_FILE"; then
    # 在今天的 "### 功能更新" 后面追加
    TEMP_FILE=$(mktemp)
    
    awk -v commit="$COMMIT" '
    /^### 功能更新$/ {
        print $0
        print ""
        print commit
        next
    }
    1
    ' "$LOG_FILE" > "$TEMP_FILE"
    
    mv "$TEMP_FILE" "$LOG_FILE"
    
    echo "✅ 更新日志已追加"
    git add "$LOG_FILE"
    echo "✅ 更新日志已暂存"
else
    # 创建新的日期区块
    TEMP_FILE=$(mktemp)
    
    awk -v date="$DATE" -v commit="$COMMIT" '
    /^---$/ {
        print ""
        print "## " date
        print ""
        print "### 功能更新"
        print ""
        print commit
        print ""
        print "---"
        next
    }
    1
    ' "$LOG_FILE" > "$TEMP_FILE"
    
    mv "$TEMP_FILE" "$LOG_FILE"
    
    echo "✅ 更新日志已追加"
    git add "$LOG_FILE"
    echo "✅ 更新日志已暂存"
fi