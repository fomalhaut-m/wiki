#!/bin/bash

LOG_FILE="docs/log/index.md"
DATE=$(date +"%Y-%m-%d")

# 检查今天是否已存在记录
if grep -q "## $DATE" "$LOG_FILE"; then
    exit 0
fi

# 获取最近5条提交
COMMITS=$(git log --format="- %s" -5 --not --grep="更新日志")

if [ -n "$COMMITS" ]; then
    # 创建临时文件
    TEMP_FILE=$(mktemp)
    
    # 找到 "---" 的位置并插入
    awk -v date="$DATE" -v commits="$COMMITS" '
    /^---$/ {
        print ""
        print "## " date
        print ""
        print "### 功能更新"
        print ""
        print commits
        print ""
        print "---"
        next
    }
    1
    ' "$LOG_FILE" > "$TEMP_FILE"
    
    mv "$TEMP_FILE" "$LOG_FILE"
    
    echo "✅ 更新日志已追加"
    git add "$LOG_FILE"
    echo "✅ 更新日志已暂存"
fi