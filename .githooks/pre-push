#!/bin/bash

# pre-push 钩子 - 在 push 前自动提交暂存的更新日志

LOG_FILE="docs/log/index.md"

# 检查是否有未提交的变更
STATUS=$(git status --porcelain "$LOG_FILE")

if [ -n "$STATUS" ]; then
    # 检查是否是暂存状态
    if echo "$STATUS" | grep -q "^A"; then
        echo "🔧 发现暂存的更新日志变更，自动提交..."
        git commit -m "chore: 更新日志" --no-verify
        echo "✅ 更新日志已自动提交"
    fi
fi

exit 0